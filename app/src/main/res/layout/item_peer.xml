<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical">

        <!-- Avatar + statut -->
        <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
            <TextView
                android:layout_width="52dp" android:layout_height="52dp"
                android:background="@drawable/circle_avatar"
                android:gravity="center"
                android:text="👤" android:textSize="22sp" android:textColor="@color/white" />
            <View
                android:id="@+id/view_status_dot"
                android:layout_width="14dp" android:layout_height="14dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/dot_available" />
        </FrameLayout>

        <!-- Infos -->
        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_peer_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/tv_peer_ip"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp" android:textColor="@color/text_secondary"
                android:fontFamily="monospace" />
            <TextView
                android:id="@+id/tv_peer_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp" android:textColor="@color/green" />
        </LinearLayout>

        <!-- Bouton appel audio -->
        <ImageView
            android:id="@+id/btn_call_audio"
            android:layout_width="38dp" android:layout_height="38dp"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/ic_menu_call"
            android:tint="@color/primary"
            android:background="@drawable/circle_control_light"
            android:padding="8dp"
            android:clickable="true" android:focusable="true"
            android:contentDescription="Appel vocal" />

        <!-- Bouton appel vidéo -->
        <ImageView
            android:id="@+id/btn_call_video"
            android:layout_width="38dp" android:layout_height="38dp"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="@color/primary"
            android:background="@drawable/circle_control_light"
            android:padding="8dp"
            android:clickable="true" android:focusable="true"
            android:contentDescription="Appel vidéo" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
